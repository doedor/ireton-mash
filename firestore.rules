rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitive Definition
    function isValidId(id) { 
        return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }

    // Validation Blueprint for faceStats
    function isValidFaceStats(data) {
      return data.keys().hasOnly(['elo', 'matches', 'updatedAt']) 
          && data.elo is number 
          && data.matches is number
          && data.updatedAt == request.time;
    }

    match /faceStats/{faceId} {
      allow get: if isSignedIn() && isValidId(faceId);
      // For global leaderboard, force query bounding
      // Client must use where("elo", ">=", 0)
      allow list: if isSignedIn() && resource.data.elo >= 0;
      
      allow create: if isSignedIn() 
          && isValidId(faceId)
          && isValidFaceStats(incoming())
          && incoming().keys().hasAll(['elo', 'matches', 'updatedAt'])
          && incoming().keys().size() == 3;

      allow update: if isSignedIn()
          && isValidId(faceId)
          && isValidFaceStats(incoming())
          && incoming().diff(existing()).affectedKeys().hasOnly(['elo', 'matches', 'updatedAt']);
          
      allow delete: if false;
    }
  }
}
